# EditorConfig — project-context.md Abschnitt 7.
# https://editorconfig.org/

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.py]
indent_size = 4
max_line_length = 100

[*.{ts,tsx,js,jsx,svelte,mjs,cjs,json,jsonc,yaml,yml,html,css,scss}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[{*.sh,*.bash}]
indent_size = 2
