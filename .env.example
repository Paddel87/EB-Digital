# EB Digital — Beispiel-Umgebungsvariablen.
# Kopiere diese Datei zu .env und ersetze die Platzhalter mit echten Werten.
# .env ist via .gitignore ausgeschlossen und darf NIE committet werden.
# Felder spiegeln backend/eb_digital/settings.py (Phase 1, Schritt 1.3) wider.

# ─── Laufzeitumgebung ──────────────────────────────────────────────────────
# dev | staging | production
ENVIRONMENT=dev

# Logging (project-context.md Abschnitt 8: INFO in prod, DEBUG nur lokal)
LOG_LEVEL=DEBUG

# ─── Backend-App-Settings ──────────────────────────────────────────────────
# Sitzungs-Signatur. Generieren z. B. mit: `python -c "import secrets; print(secrets.token_urlsafe(64))"`
SECRET_KEY=GENERATE_ME_64_CHAR_RANDOM_TOKEN

# Cookie-Name für Starlette-Session (project-context.md Abschnitt 6 Sicherheit)
SESSION_COOKIE_NAME=eb_session

# ─── Datenbank ─────────────────────────────────────────────────────────────
# PostgreSQL 17.9 — async-tauglicher Driver (asyncpg) wird in Schritt 1.4 fixiert.
DATABASE_URL=postgresql+asyncpg://eb_digital:CHANGE_ME@db:5432/eb_digital

# Container-Init-Werte (für docker-compose dev-Profil; in Schritt 1.8 aktiv)
POSTGRES_USER=eb_digital
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=eb_digital

# ─── Cache + Pub/Sub ───────────────────────────────────────────────────────
# Valkey 8.1.7 (NICHT Redis — Lizenz-Constraint, project-context.md Abschnitt 3)
VALKEY_URL=valkey://cache:6379/0

# ─── Externe Karten-/Routing-Services ──────────────────────────────────────
# Backend-seitig, NIEMALS im Frontend-Bundle (Regel-004)
TOMTOM_API_KEY=GENERATE_ME_AT_DEVELOPER_TOMTOM_COM
MAPTILER_API_KEY=GENERATE_ME_AT_MAPTILER_COM

# Tile-Proxy-Basis-URL (intern via nginx-Container, Schritt 1.8)
TILE_PROXY_BASE=http://tile-proxy:80

# ─── Reverse-Proxy ─────────────────────────────────────────────────────────
# Lokale Domain für Caddy-internes TLS in dev (Schritt 1.8)
PUBLIC_DOMAIN=eb.local
