# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.nox/

# uv (Lock-File ist commit-pflichtig, Cache nicht)
.venv/
.uv-cache/

# Node / pnpm (Lock-File ist commit-pflichtig, Cache nicht)
node_modules/
.pnpm-store/

# SvelteKit / Vite
.svelte-kit/
.vite/

# Build-Output Frontends
apps/*/build/
apps/*/.output/
apps/*/dist/

# Environments und Secrets (project-context.md Abschnitt 6)
.env
.env.*
!.env.example

# IDE / Editor
.idea/
.vscode/
!.vscode/extensions.json
*.swp
*.swo

# Claude-Code-Tooling (Browser-Smoke-Konfig, lokale Worktree-Settings).
# Tool-spezifisch, nicht Pflicht-Artefakt.
.claude/

# OS
.DS_Store
Thumbs.db

# Lokale Test- und Debug-Artefakte
*.log
*.pid
*.seed
*.bak
.tmp/
tmp/

# Lokale Daten (Volume-Mounts aus docker-compose dev-Profil)
.data/
data/
volumes/
