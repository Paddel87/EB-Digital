{
  "name": "frontend-betreuer",
  "version": "0.1.0",
  "private": true,
  "description": "EB Digital Betreuer-Frontend (Mobile-PWA mit Offline-Pufferung).",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 5174",
    "build": "vite build",
    "preview": "vite preview --port 5174",
    "sync": "svelte-kit sync",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "tsc": "svelte-kit sync && tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "svelte-kit sync && vitest run --passWithNoTests"
  },
  "devDependencies": {
    "@eslint/js": "~10.0.0",
    "@sveltejs/adapter-static": "~3.0.10",
    "@sveltejs/kit": "~2.59.0",
    "@sveltejs/vite-plugin-svelte": "~7.1.0",
    "@types/node": "~24.12.0",
    "@vitest/coverage-v8": "~4.1.0",
    "eslint": "~10.3.0",
    "eslint-plugin-security": "~4.0.0",
    "eslint-plugin-svelte": "~3.17.0",
    "prettier": "~3.8.0",
    "prettier-plugin-svelte": "~3.5.0",
    "svelte": "~5.55.0",
    "svelte-check": "~4.4.0",
    "svelte-eslint-parser": "~1.6.0",
    "typescript": "6.0.3",
    "typescript-eslint": "~8.59.0",
    "vite": "~8.0.0",
    "vite-plugin-pwa": "~1.3.0",
    "vitest": "~4.1.0"
  }
}
